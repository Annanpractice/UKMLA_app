name = "ukmla-ai-quiz"
main = "ukmla-ai-worker.js"
compatibility_date = "2026-07-10"

[vars]
# Replace with the exact GitHub Pages origin after deployment.
ALLOWED_ORIGIN = "https://annanpractice.github.io"
OPENAI_MODEL = "gpt-5-mini"

# Never put OPENAI_API_KEY in this file.
# Add it securely with:
#   npx wrangler secret put OPENAI_API_KEY
